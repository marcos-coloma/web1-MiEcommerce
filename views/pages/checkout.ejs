<!DOCTYPE html>
<html lang="es">

<%- include('../partials/head', { title: 'Home' }) %>

<body>

    <%- include('../partials/header', { perfilLink: '/login' }) %>

<main class="checkout-container">

    <section class="checkout-opciones">

        <h2>Elegí la forma de entrega</h2>

        <div class="opcion">
            <div class="caja-1">
                <input type="radio" name="entrega">
                <div>
                    <p class="tamaño-p"><strong>Enviar a domicilio</strong></p>
                    <p>calle ejemplo 236 casa 72 -Villa Mercedes, San Luis - CP5730</p>
                </div>
            </div>

            <div class="caja-2">
                <span class="gratis">Gratis</span>
            </div>
        </div>

        <div class="opcion">
            <div class="caja-1">
                <input type="radio" name="entrega">
                <div>
                    <p class="tamaño-p"><strong>Retirar en un punto de entrega</strong></p>
                    <p>Sucursal OCA - SAN MARTIN 319 - VA.MERCEDES</p>
                </div>
            </div>

            <div class="caja-2">
                <span class="gratis">Gratis</span>
            </div>
        </div>

        <a href="#">
            <button class="btn-continuar">Continuar</button>
        </a>

    </section>


    <aside class="checkout-resumen">

        <h3>Resumen de compra</h3>

        <div class="resumen-item">
            <span>Producto</span>
            <span>$9.750</span>
        </div>

        <div class="resumen-item">
            <span>Envío</span>
            <span class="gratis">Gratis</span>
        </div>

        <hr>

        <div class="resumen-total">
            <strong>Total</strong>
            <strong>$9.750</strong>
        </div>

    </aside>

</main>

    <footer>
        <div class="pie-de-pagina">
            <div class="grupo-1">
                <a href="https://twitter.com" target="_blank" rel="noopener">
                    <img src="/img/Logo twitter.png" alt="twitter" class="imagen-pie">
                </a>
                <a href="https://facebook.com" target="_blank" rel="noopener">
                    <img src="/img/Logo facebook.png" alt="facebook" class="imagen-pie">
                </a>
                <a href="https://youtube.com" target="_blank" rel="noopener">
                    <img src="/img/Logo youtube.png" alt="youtube" class="imagen-pie">
                </a>
                <a href="https://instagram.com" target="_blank" rel="noopener">
                    <img src="/img/Logo instagram.png" alt="instagram" class="imagen-pie">
                </a>
            </div>

            <div class="grupo-2">
                <p>@ MiEcommerce. Todos los derechos reservados.</p>
            </div>

            <div class="grupo-3">
                <a href="https://www.apple.com/app-store/" target="_blank" rel="noopener" class="boton-app">
                    <img src="/img/Logo app store.png" alt="App Store" class="imagen-pie">
                    <span class="descripcion-pie">App Store</span>
                </a>
                <a href="https://play.google.com/store" target="_blank" rel="noopener" class="boton-app">
                    <img src="/img/logo google play.png" alt="Google Play" class="imagen-pie">
                    <span class="descripcion-pie">Google Play</span>
                </a>
            </div>
        </div>
    </footer>
</body>
</html>