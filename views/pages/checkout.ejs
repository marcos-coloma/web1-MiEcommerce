            <span>Envío</span>
            <span class="gratis">Gratis</span>
        </div>

        <hr>

        <div class="resumen-total">
            <strong>Total</strong>
            <strong>$9.750</strong>
        </div>

    </aside>

</main>

<%- include('../partials/footer') %>

