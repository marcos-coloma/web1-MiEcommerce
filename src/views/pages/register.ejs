<div class="auth-container">
    <div class="auth-card">
        <span class="auth-title">¡Hola!</span>

        <form id="register-form" action="/register" method="POST">
            <ul id="auth-errors"></ul>

            <input id="email" name="email" type="text" placeholder="Tu email" class="auth-input">
            <input id="password" name="password" type="password" placeholder="Tu contraseña" class="auth-input">
            <input id="repeatPassword" name="repeatPassword" type="password" placeholder="Repite tu contraseña" class="auth-input">

            <button type="submit" class="auth-button">
                Crear Cuenta
            </button>
        </form>
    </div>
</div>

<div class="auth-footer"> 
    <span>¿Ya tienes una cuenta?&nbsp;</span>
    <a href="/login" class="auth-link">inicia sesión</a>
</div>

<script src="/js/validations.js" defer></script>
<script src="/js/registerValidation.js" defer></script>