<!DOCTYPE html>
<html lang="es">

<%- include('../partials/head', { title: 'Cart' }) %>

<body>

    <%- include('../partials/header', { perfilLink: '/login' }) %>

    <main>
        <a href="/" class="volver-listado">
            <div class="subtitulo-2">
                <img src="/img/ui/flecha-izquierda.png" alt="<-">
                <span>Volver</span>
            </div>
        </a>
        
        <div class="subtitulo-3">
            <h2>Productos en tu Carrito</h2>
        </div>


        <% if (cart.length === 0) { %>

            <div class="carrito-vacio">
                <p>No hay productos en tu carrito</p>
                <a href="/">Ver productos</a>
            </div>

        <% } else { %>

            <% cart.forEach(product => { %>

        <div class="carrito-caja">
            <div class="caja-1">
                <img src="<%= product.img || '/img/placeholder.jpg' %>" 
                    class="imagen-carrito">

                <p class="tamaño-p"><%= product.name %></p>
            </div>

        <div class="caja-2">


            <div class="sesion sesion-margen">
                <form action="/cart/remove/<%= product.id %>" method="POST">
                    <button type="submit">Quitar</button>
                </form>
            </div>

        <div class="cantidad">

            <form action="/cart/decrease/<%= product.id %>" method="POST" style="display:inline;">
                <button type="submit">-</button>
            </form>

            <span><%= product.quantity %></span>

            <form action="/cart/increase/<%= product.id %>" method="POST" style="display:inline;">
                <button type="submit">+</button>
            </form>

        </div>

    </div>

                    <span class="puntos"><%= product.subtotal %></span>
                </div>
            </div>

            <% }) %>

        <% } %>

        <div class="Total">
            <p class="puntos">Total de puntos: <span style="font-size: 1.8rem;"><%= total %></span></p>
        </div>


        <% if (cart.length > 0) { %>
            <div class="sesion sesion-3">
                <a href="/checkout">Ir a Pagar</a>
            </div>
        <% } else { %>
            <div class="sesion sesion-3">
                <a href="#" style="opacity: 0.8; pointer-events: none; text-align: center;">
                    Carrito vacío
                </a>
            </div>
        <% } %>

    </main>

    <%- include('../partials/footer') %>

</body>
</html>