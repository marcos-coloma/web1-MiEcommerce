<!DOCTYPE html>
<html lang="es">

    <%- include('../partials/head', { title: 'Login' }) %>

    <body>
        <header class="encabezado-login">
            <a href="/">
                <span class="Logo"><strong>Mi</strong>Ecommerce</span>
            </a>
        </header>


        <main>

            <div class="auth-container">
                <div class="auth-card">
                    <span class="auth-title">¡Hola!</span>

                    <form action="/">
                        <ul id="auth-errors"></ul>

                        <input id="username" type="text" placeholder="Tu nombre de usuario" class="auth-input">
                        <input id="password" type="password" placeholder="Tu contraseña" class="auth-input">

                        <button type="submit" class="auth-button">
                            Crear Cuenta
                        </button>

                    </form>
                </div>
            </div>

            <div class="auth-footer"> 
                <span>¿No tienes una cuenta?&nbsp;</span>
                <a href="/register" class="auth-link">registrate</a>
            </div>

        </main>

        <%- include('../partials/footer') %>

        <script src="/js/validations.js"></script>
        <script src="/js/loginValidation.js"></script>
    </body>
</html>