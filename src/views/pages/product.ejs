<!DOCTYPE html>
<html lang="es">

<%- include('../partials/head', { title: product.name }) %>

<body>
    
<%- include('../partials/header', { perfilLink: '/login' }) %>

<main>

    <a href="/products" class="volver-listado">
        <div class="subtitulo-2">
            <img src="/img/flecha-izquierda.png" alt="<-">
            <span>Volver al listado</span>
            <img src="/img/flecha-derecha.png" alt="->">
            <span>alimentos</span>
        </div>
    </a>

    <div class="producto-whiskey">
        <div class="producto-whiskey-contenido">

            <img src="<%= product.img %>" alt="<%= product.name %>" class="producto-img">

            <div class="producto-whiskey-contenido-descripcion">
                <h2>
                    <%= product.name %> <br>
                    <span style="font-size: 40px;">
                        $ <%= product.price.toLocaleString() %>
                    </span>
                    <span style="color: gray; font-size: 15px;">PUNTOS</span>
                </h2>

                <form action="/cart/add/<%= product.id %>" method="POST">
                    <button type="submit">Agregar al carrito</button>
                </form>

                <br>

                <p style="font-size: 15px; color: rgb(54, 54, 54);">
                    <%= product.description %>
                </p>
            </div>

        </div>
    </div>

    <h2 class="subtitulo">Te puede interesar</h2>

    <div class="cuerpo">
        <% products.forEach(p => { %>
            <%- include('../partials/productCard', { product: p }) %>
        <% }) %>
    </div>

    <%- include('../partials/categories', { recuadroClass: 'recuadro-2' }) %>

</main>

<%- include('../partials/footer') %>

</body>
</html>