<!DOCTYPE html>
<html lang="es">

<%- include('../partials/head', { title: product.name }) %>

<body>
    
<%- include('../partials/header', { perfilLink: '/login' }) %>

<main>

    <a href="/" class="volver-listado">
        <div class="subtitulo-2">
            <img src="/img/ui/flecha-izquierda.png" alt="<-">
            <span>Volver al listado</span>
            <img src="/img/ui/flecha-derecha.png" alt="->">
            <span><%= product.category.charAt(0).toUpperCase() + product.category.slice(1) %></span>
        </div>
    </a>

    <div class="producto-whiskey">
        <div class="producto-whiskey-contenido">

        <img 
            src="<%= product.img || '/img/products/placeholder.webp' %>" 
            alt="<%= product.name %>" 
            class="producto-img"
            onerror="this.onerror=null; this.src='/img/products/placeholder.webp';">

            <div class="producto-whiskey-contenido-descripcion">
                <h2>
                    <%= product.name %> <br>
                    <span style="font-size: 40px;">
                        $ <%= product.price.toLocaleString() %>
                    </span>
                    <span style="color: gray; font-size: 15px;">PUNTOS</span>
                </h2>

        <form action="/cart/add/<%= product.id %>" method="POST">
            
            <% if (product.stock === 0) { %>

                <button type="button" class="sesion" disabled>
                    Sin stock
                </button>

            <% } else { %>

                <button type="submit" class="sesion">
                    Agregar al carrito
                </button>

            <% } %>

        </form>

                <br>

                <p style="font-size: 15px; color: rgb(54, 54, 54);">
                    <%= product.description %>
                </p>
            </div>

        </div>
    </div>

    <h2 class="subtitulo">Productos relacionados</h2>

    <% if (relatedProducts.length > 0) { %>

        <div class="cuerpo">
            <% relatedProducts.forEach(p => { %>
                <%- include('../partials/productCard', { product: p }) %>
            <% }) %>
        </div>

    <% } else { %>

        <p>No hay productos relacionados disponibles.</p>

    <% } %>

    <%- include('../partials/categories', { recuadroClass: 'recuadro-2' }) %>

</main>

<%- include('../partials/footer') %>

</body>
</html>