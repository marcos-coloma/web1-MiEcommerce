<!DOCTYPE html>
<html lang="es">

<%- include('../partials/head', { title: product.name }) %>

<body>
    
<%- include('../partials/header', { perfilLink: '/login' }) %>

<main>

    <a href="/" class="back-link">
        <div class="product-breadcrumb">
            <img src="/img/ui/flecha-izquierda.png" alt="<-">
            <span>Volver al listado</span>
            <img src="/img/ui/flecha-derecha.png" alt="->">
            <span><%= product.category.charAt(0).toUpperCase() + product.category.slice(1) %></span>
        </div>
    </a>

    <div class="product-detail">
        <div class="product-detail-container">

            <img 
                src="<%= product.img || '/img/products/placeholder.webp' %>" 
                alt="<%= product.name %>" 
                class="product-image"
                onerror="this.onerror=null; this.src='/img/products/placeholder.webp';">

            <div class="product-info">

                <h2>
                    <%= product.name %> <br>
                    <span class="product-price">
                        $ <%= (product.price || 0).toLocaleString() %>
                    </span>
                    <span class="product-points">PUNTOS</span>
                </h2>

                <form action="/cart/add/<%= product.id %>" method="POST">

                    <% if (product.stock === 0) { %>

                        <button type="button" class="btn" disabled>
                            Sin stock
                        </button>

                    <% } else { %>

                        <button type="submit" class="btn">
                            Agregar al carrito
                        </button>

                    <% } %>

                </form>

                <p class="product-description">
                    <%= product.description %>
                </p>

            </div>

        </div>
    </div>

    <h2 class="section-title">Productos relacionados</h2>

    <% if (relatedProducts.length > 0) { %>

        <div class="product-grid">
            <% relatedProducts.forEach(p => { %>
                <%- include('../partials/productCard', { product: p }) %>
            <% }) %>
        </div>

    <% } else { %>

        <p>No hay productos relacionados disponibles.</p>

    <% } %>

<%- include('../partials/categories', { categoryWrapperClass: 'category-wrapper-alt' }) %>

</main>

<%- include('../partials/footer') %>

</body>
</html>